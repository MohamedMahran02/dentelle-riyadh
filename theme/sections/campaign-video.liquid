{%- liquid
  assign video = section.settings.video
  assign video_url = section.settings.video_url
  assign poster = section.settings.poster
-%}

<section class="campaign" id="shopify-section-{{ section.id }}" data-reveal>
  <div class="campaign__media">
    {%- if video != blank -%}
      {{ video | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        controls: false,
        image_size: '1600x',
        poster: poster
      }}
    {%- elsif video_url != blank -%}
      <video autoplay muted loop playsinline preload="metadata" {% if poster %}poster="{{ poster | image_url: width: 1600 }}"{% endif %}>
        <source src="{{ video_url }}" type="video/mp4">
        {%- if poster -%}
          {{ poster | image_url: width: 1600 | image_tag: alt: 'Campaign still' }}
        {%- endif -%}
      </video>
    {%- elsif poster != blank -%}
      {{ poster | image_url: width: 1600 | image_tag:
        widths: '800,1200,1600,2000',
        sizes: '100vw',
        alt: section.settings.heading | default: 'Campaign',
        loading: 'lazy'
      }}
    {%- else -%}
      <div style="width:100%;height:100%;background:linear-gradient(135deg,#2A2521,#0E0B09);"></div>
    {%- endif -%}
    <div class="campaign__scrim" aria-hidden="true"></div>
  </div>

  <div class="campaign__overlay">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow eyebrow--light">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="h-display h-display--light">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn--ghost-light">{{ section.settings.button_label | escape }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.campaign.name",
  "settings": [
    { "type": "video", "id": "video", "label": "Campaign video (uploaded to Shopify)" },
    { "type": "url", "id": "video_url", "label": "…or MP4 URL (used if video is blank)" },
    { "type": "image_picker", "id": "poster", "label": "Poster image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Campaign · مُهره" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p><em>Of quiet</em><br>confidence.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Watch the film" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "t:sections.campaign.name" }]
}
{% endschema %}
