<section class="full-bleed" data-reveal>
  <div class="full-bleed__media" data-parallax>
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: widths: '1200,1800,2400', sizes: '100vw', alt: section.settings.heading | strip_html, loading: 'lazy' }}
    {%- endif -%}
  </div>
  <div class="full-bleed__overlay">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow eyebrow--light">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="h-display h-display--light">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn--ghost-light">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Full bleed editorial",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Journal — Volume I" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p><em>Of light,</em><br>and lace.</p>" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "A series of letters from the atelier — on fabric, on form, on the women who move within." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Read the journal" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Full bleed" }]
}
{% endschema %}
