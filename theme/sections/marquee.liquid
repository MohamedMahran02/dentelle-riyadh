<div class="marquee" aria-hidden="true">
  <div class="marquee__track">
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}
        <span {{ block.shopify_attributes }}{% if block.settings.rtl %} dir="rtl" lang="ar"{% endif %}>{{ block.settings.text | escape }}</span>
        <span class="marquee__dot">✦</span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.marquee.name",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Mohrah Collection" },
        { "type": "checkbox", "id": "rtl", "label": "Arabic (right-to-left)", "default": false }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "item", "settings": { "text": "مُهره", "rtl": true } },
      { "type": "item", "settings": { "text": "Mohrah Collection" } },
      { "type": "item", "settings": { "text": "Dentelle Riyadh" } },
      { "type": "item", "settings": { "text": "Made in the Kingdom" } }
    ]
  },
  "presets": [{ "name": "t:sections.marquee.name" }]
}
{% endschema %}
