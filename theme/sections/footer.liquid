{%- liquid
  assign wordmark = section.settings.wordmark | default: 'Dentelle'
  assign city = section.settings.city | default: 'Riyadh'
-%}

<footer class="site-footer" id="contact" role="contentinfo">
  <div class="site-footer__top">
    <div class="site-footer__brand">
      <svg class="logo-mark" viewBox="0 0 120 140" fill="currentColor" aria-hidden="true">
        <path d="M60 6 L66 26 L86 32 L66 38 L60 58 L54 38 L34 32 L54 26 Z" opacity=".9"/>
      </svg>
      <span class="site-logo__wordmark">{{ wordmark | escape }}</span>
      <span class="site-logo__city">{{ city | escape }}</span>
      {%- if section.settings.tagline != blank -%}
        <p class="site-footer__tagline">{{ section.settings.tagline | escape }}</p>
      {%- endif -%}

      {%- if section.settings.instagram_url != blank or section.settings.tiktok_url != blank or section.settings.whatsapp_url != blank -%}
        <div class="site-footer__social">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" rel="noopener">IG</a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a href="{{ section.settings.tiktok_url }}" aria-label="TikTok" rel="noopener">TT</a>
          {%- endif -%}
          {%- if section.settings.whatsapp_url != blank -%}
            <a href="{{ section.settings.whatsapp_url }}" aria-label="WhatsApp" rel="noopener">WA</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'menu' -%}
        <div class="site-footer__col" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <h4>{{ block.settings.title | escape }}</h4>
          {%- endif -%}

          {%- assign menu = block.settings.menu -%}
          {%- if menu != blank and menu.links.size > 0 -%}
            {%- for link in menu.links -%}
              {%- comment -%} Bilingual mode: if translations key like `footer_links.<handle>` exists, show AR next to EN. Otherwise plain link. {%- endcomment -%}
              {%- assign handle = link.title | handleize -%}
              {%- capture translation_key -%}footer_links.{{ handle }}{%- endcapture -%}
              {%- assign translated = translation_key | t -%}
              {%- if translated != translation_key and translated != blank -%}
                <a class="bilingual-link" href="{{ link.url }}">
                  <span>{{ link.title | escape }}</span>
                  <span dir="rtl" lang="ar">{{ translated | escape }}</span>
                </a>
              {%- else -%}
                <a href="{{ link.url }}">{{ link.title | escape }}</a>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="site-footer__base">
    <small>© {{ 'now' | date: '%Y' }} {{ shop.name }} — {{ section.settings.copyright | default: 'All rights reserved.' | escape }}</small>
    {%- if section.settings.city_line != blank -%}
      <small>{{ section.settings.city_line | escape }}</small>
    {%- endif -%}
    {%- if shop.published_locales.size > 1 -%}
      <small>
        {%- for locale in shop.published_locales -%}
          <a class="locale-btn{% if locale.iso_code == request.locale.iso_code %} is-active{% endif %}" href="{% if locale.primary %}{{ routes.root_url }}{% else %}/{{ locale.iso_code }}{% endif %}" hreflang="{{ locale.iso_code }}">{{ locale.iso_code | upcase }}</a>
          {%- unless forloop.last -%} · {%- endunless -%}
        {%- endfor -%}
      </small>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    { "type": "text", "id": "wordmark", "label": "Wordmark", "default": "Dentelle" },
    { "type": "text", "id": "city", "label": "City", "default": "Riyadh" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "A refined language for femininity — rooted in heritage, refined by modernity." },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "All rights reserved." },
    { "type": "text", "id": "city_line", "label": "City line", "default": "Riyadh · KSA · by appointment" },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "url", "id": "whatsapp_url", "label": "WhatsApp URL" },
    { "type": "paragraph", "content": "Bilingual labels: add translations in `locales/ar.json` under `footer_links.<link-handle>` — e.g. `footer_links.philosophy: \"فلسفتنا\"` — and they will appear next to English links automatically." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column title", "default": "The Maison" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "menu", "settings": { "title": "The Maison" } },
      { "type": "menu", "settings": { "title": "Client care" } },
      { "type": "menu", "settings": { "title": "Shop" } },
      { "type": "menu", "settings": { "title": "Legal" } }
    ]
  }
}
{% endschema %}
