<section class="not-found" id="Main404-{{ section.id }}">
  <div class="not-found__inner">
    <span class="eyebrow">404</span>
    <h1 class="h-display">Page not <em>found.</em></h1>
    <p>The page you are looking for does not exist, or has been moved.</p>
    <a href="{{ routes.root_url }}" class="btn">Return home</a>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "settings": []
}
{% endschema %}
