<header class="site-header" id="siteHeader">
  <div class="site-header__inner">
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" data-menu-toggle>
      <span></span><span></span>
    </button>

    <nav class="site-nav site-nav--left" aria-label="Primary">
      {%- for link in section.settings.menu_primary.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <a href="{{ routes.root_url }}" class="site-logo" aria-label="{{ shop.name }} — Home">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 240 | image_tag: class: 'site-logo__image', alt: shop.name, loading: 'eager' }}
      {%- else -%}
        <svg class="logo-mark" viewBox="0 0 120 140" fill="currentColor" aria-hidden="true">
          <path d="M60 6 L66 26 L86 32 L66 38 L60 58 L54 38 L34 32 L54 26 Z" opacity=".9"/>
        </svg>
        <span class="site-logo__wordmark">{{ section.settings.wordmark | default: shop.name }}</span>
        <span class="site-logo__city">{{ section.settings.city | default: 'Riyadh' }}</span>
      {%- endif -%}
    </a>

    <nav class="site-nav site-nav--right" aria-label="Secondary">
      {%- for link in section.settings.menu_secondary.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
      <a href="{{ routes.search_url }}" class="icon-link" aria-label="{{ 'general.search' | t }}">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="icon-link" aria-label="{{ 'general.cart' | t }}">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1"><path d="M6 8h12l-1 12H7L6 8Z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></svg>
        <span class="bag-count">{{ cart.item_count }}</span>
      </a>
    </nav>
  </div>
</header>

<aside class="mobile-panel" data-menu-panel aria-hidden="true">
  <div class="mobile-panel__inner">
    {%- for link in section.settings.menu_primary.links -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {%- endfor -%}
    {%- for link in section.settings.menu_secondary.links -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {%- endfor -%}
    <div class="mobile-panel__locale">
      {%- for locale in shop.published_locales -%}
        <a class="locale-btn {% if locale.iso_code == request.locale.iso_code %}is-active{% endif %}" href="/{{ locale.iso_code }}">{{ locale.iso_code | upcase }}</a>
        {%- unless forloop.last -%}<span>·</span>{%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</aside>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image (optional — leave blank to use wordmark)" },
    { "type": "text", "id": "wordmark", "label": "Wordmark", "default": "Dentelle" },
    { "type": "text", "id": "city", "label": "City / tagline", "default": "Riyadh" },
    { "type": "link_list", "id": "menu_primary", "label": "Primary menu", "default": "main-menu" },
    { "type": "link_list", "id": "menu_secondary", "label": "Secondary menu" }
  ]
}
{% endschema %}
