{%- liquid
  paginate collection.products by section.settings.products_per_page
-%}

<section class="collection" id="MainCollection-{{ section.id }}" data-reveal>
  <header class="collection__header">
    <span class="eyebrow">{{ 'collection.title' | t }}</span>
    <h1 class="h-display">
      <span>{{ collection.title | escape }}</span>
      {%- assign title_ar = collection.metafields.custom.title_ar -%}
      {%- if title_ar != blank -%}
        <span class="h-display-ar" dir="rtl" lang="ar">{{ title_ar | escape }}</span>
      {%- endif -%}
    </h1>
    {%- if collection.description != blank -%}
      <div class="collection__description rte">{{ collection.description }}</div>
    {%- endif -%}
    <p class="collection__count">{{ 'collection.items' | t: count: collection.products_count }}</p>
  </header>

  {%- if section.settings.show_sort -%}
    <div class="collection__toolbar">
      <form class="collection__sort" data-collection-sort>
        <label for="SortBy" class="eyebrow">{{ 'collection.sort_by' | t }}</label>
        <select id="SortBy" name="sort_by" onchange="this.form.submit()">
          {%- assign sort_options = 'manual,best-selling,title-ascending,title-descending,price-ascending,price-descending,created-ascending,created-descending' | split: ',' -%}
          {%- for value in sort_options -%}
            <option value="{{ value }}" {% if collection.sort_by == value or collection.default_sort_by == value and collection.sort_by == null %}selected{% endif %}>{{ value | replace: '-', ' ' | capitalize }}</option>
          {%- endfor -%}
        </select>
      </form>
    </div>
  {%- endif -%}

  <div class="product-grid__items">
    {%- for product in collection.products -%}
      {% render 'product-card', product: product, badge: 'Signature' %}
    {%- else -%}
      <p class="collection__empty">{{ 'collection.empty' | t }}</p>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <nav class="pagination" aria-label="Pagination">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="pagination__link">‹ Previous</a>
      {%- endif -%}
      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a href="{{ part.url }}" class="pagination__link">{{ part.title }}</a>
        {%- else -%}
          <span class="pagination__current">{{ part.title }}</span>
        {%- endif -%}
      {%- endfor -%}
      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="pagination__link">Next ›</a>
      {%- endif -%}
    </nav>
  {%- endif -%}
</section>

{%- endpaginate -%}

{% schema %}
{
  "name": "t:sections.main-collection.name",
  "settings": [
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 24 },
    { "type": "checkbox", "id": "show_sort", "label": "Show sort dropdown", "default": true }
  ]
}
{% endschema %}
