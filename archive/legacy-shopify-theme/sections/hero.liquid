{%- liquid
  assign img = section.settings.image
  assign heading = section.settings.heading | default: 'Mohra.'
  assign label_en = section.settings.label_en
  assign label_ar = section.settings.label_ar
-%}

<section class="hero hero--aubade" id="hero-{{ section.id }}">
  <div class="hero__media" data-parallax>
    {%- if img != blank -%}
      {{ img | image_url: width: 2400 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        widths: '800,1200,1600,2000,2400',
        sizes: '100vw',
        alt: img.alt | default: heading
      }}
    {%- else -%}
      <div style="width:100%;height:100%;background:linear-gradient(135deg,#2A2521,#0E0B09);"></div>
    {%- endif -%}

    {%- if label_en != blank or label_ar != blank -%}
      <div class="hero__label reveal-stagger" style="--d:.6s">
        {%- if label_en != blank -%}<span class="hero__label-en">{{ label_en | escape }}</span>{%- endif -%}
        {%- if label_ar != blank -%}<span class="hero__label-ar" dir="rtl" lang="ar">{{ label_ar | escape }}</span>{%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="hero__caption">
    <h1 class="hero__title display reveal-stagger" style="--d:.3s">
      <em>{{ heading | escape }}</em>
    </h1>

    {%- if section.settings.eyebrow != blank -%}
      <span class="hero__eyebrow eyebrow reveal-stagger" style="--d:.15s">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}

    {%- if section.settings.lede != blank -%}
      <p class="hero__lede reveal-stagger" style="--d:.5s">{{ section.settings.lede }}</p>
    {%- endif -%}

    <div class="hero__cta reveal-stagger" style="--d:.65s">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn">{{ section.settings.button_label | escape }}</a>
      {%- endif -%}
      {%- if section.settings.link_label != blank -%}
        <a href="{{ section.settings.link_url }}" class="link-underline">{{ section.settings.link_label | escape }} ›</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.hero.name",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "header", "content": "Overlay label" },
    { "type": "text", "id": "label_en", "label": "Label (English)", "default": "Collection N°01 · Mohra" },
    { "type": "text", "id": "label_ar", "label": "Label (Arabic)", "default": "مجموعة مُهره" },
    { "type": "header", "content": "Caption" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Mohra." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Mohra Collection" },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "A refined language for femininity — rooted in heritage, refined by modernity. Every piece is hand-finished in our Riyadh atelier." },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "Discover the pieces" },
    { "type": "url", "id": "button_link", "label": "Primary button link" },
    { "type": "text", "id": "link_label", "label": "Secondary link", "default": "Read the story" },
    { "type": "url", "id": "link_url", "label": "Secondary link URL" }
  ],
  "presets": [{ "name": "t:sections.hero.name" }]
}
{% endschema %}
