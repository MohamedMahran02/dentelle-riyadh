<section class="savoir" id="shopify-section-{{ section.id }}" data-reveal>
  <header class="savoir__header">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="h-display">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </header>

  <div class="savoir__grid">
    {%- if section.settings.image_tall != blank -%}
      <figure class="savoir__fig savoir__fig--tall">
        {{ section.settings.image_tall | image_url: width: 900 | image_tag:
          widths: '320,480,640,900,1200',
          sizes: '(max-width:960px) 100vw, 33vw',
          alt: section.settings.caption_tall | default: 'Atelier',
          loading: 'lazy'
        }}
        {%- if section.settings.caption_tall != blank -%}
          <figcaption>{{ section.settings.caption_tall | escape }}</figcaption>
        {%- endif -%}
      </figure>
    {%- endif -%}

    <div class="savoir__text">
      {%- if section.settings.lede != blank -%}
        <p class="savoir__lede">{{ section.settings.lede }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="savoir__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <li {{ block.shopify_attributes }}><span>{{ block.settings.index | escape }}</span>{{ block.settings.text | escape }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.link_label != blank -%}
        <a href="{{ section.settings.link_url }}" class="link-underline">{{ section.settings.link_label | escape }} ›</a>
      {%- endif -%}
    </div>

    {%- if section.settings.image_short != blank -%}
      <figure class="savoir__fig savoir__fig--short">
        {{ section.settings.image_short | image_url: width: 900 | image_tag:
          widths: '320,480,640,900',
          sizes: '(max-width:960px) 100vw, 33vw',
          alt: section.settings.caption_short | default: 'Detail',
          loading: 'lazy'
        }}
        {%- if section.settings.caption_short != blank -%}
          <figcaption>{{ section.settings.caption_short | escape }}</figcaption>
        {%- endif -%}
      </figure>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.savoir-faire.name",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Savoir-faire · الحِرفة" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>The Dentelle <em>atelier.</em></p>" },
    { "type": "image_picker", "id": "image_tall", "label": "Tall image (left)" },
    { "type": "text", "id": "caption_tall", "label": "Tall caption", "default": "Handwork — Riyadh" },
    { "type": "richtext", "id": "lede", "label": "Lede", "default": "<p><em>Each piece is a conversation</em> — between the atelier's hands, French silks and Calais laces, and the private rhythms of the woman who will wear it.</p>" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Book a size consultation" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "image_picker", "id": "image_short", "label": "Short image (right)" },
    { "type": "text", "id": "caption_short", "label": "Short caption", "default": "Detail — Mohra N°01" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature line",
      "settings": [
        { "type": "text", "id": "index", "label": "Index", "default": "01" },
        { "type": "text", "id": "text", "label": "Text", "default": "Fully customisable by appointment" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "feature", "settings": { "index": "01", "text": "Fully customisable by appointment" } },
      { "type": "feature", "settings": { "index": "02", "text": "French Leavers lace · Calais" } },
      { "type": "feature", "settings": { "index": "03", "text": "Silk satin · Lyon" } },
      { "type": "feature", "settings": { "index": "04", "text": "SASO certified, made in the Kingdom" } }
    ]
  },
  "presets": [{ "name": "t:sections.savoir-faire.name" }]
}
{% endschema %}
